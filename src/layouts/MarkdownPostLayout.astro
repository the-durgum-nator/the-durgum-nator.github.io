---
import BasePageLayout from "./BasePageLayout.astro";
import "../styles/global.css"
const { frontmatter } = Astro.props;

//to do later: seperate project/blog layouts with optional pictures/videos/links, etc.
---

<BasePageLayout pageTitle={frontmatter.title} showTitle={false}>
  <meta charset="utf-8" />
    <h2 class ="content-title-child">{frontmatter.title}</h2>
  <div class="content">
    <slot />
  </div>

  <div id="lightbox" style="display:none;">
  <div id="lightbox-inner">
    <img id="lightbox-img" src="" alt="" />
    <em id="lightbox-caption"></em>
    <p id="lightbox-hint">click anywhere or press esc to close</p>
  </div>
</div>

<style>
  #lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 999;
    cursor: default;
  }

  #lightbox-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  #lightbox img {
    max-width: 90vw;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 0.3em;
    cursor:zoom-out;
  }

  #lightbox-caption {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.85rem;
    font-style: italic;
  }

  #lightbox-hint {
    color: rgba(255, 255, 255, 0.25);
    font-size: 0.75rem;
    margin: 0;
  }


  .content p:has(img) img {
    cursor: zoom-in;
    
  }



</style>

<script>
  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
  const lightboxCaption = document.getElementById("lightbox-caption");

  if (lightbox && lightboxImg && lightboxCaption) {
    document.querySelectorAll(".content p img").forEach(img => {
      img.addEventListener("click", () => {
        lightboxImg.src = (img as HTMLImageElement).src;
        lightboxImg.alt = (img as HTMLImageElement).alt;

        // grab the sibling em for the caption if it exists
        const em = img.closest("p")?.querySelector("em");
        lightboxCaption.textContent = em ? em.textContent : "";

        lightbox.style.display = "flex";
      });
    });

    lightbox.addEventListener("click", () => {
      lightbox.style.display = "none";
      lightboxImg.src = "";
      lightboxCaption.textContent = "";
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        lightbox.style.display = "none";
        lightboxImg.src = "";
        lightboxCaption.textContent = "";
      }
    });
  }
</script>
</BasePageLayout>

