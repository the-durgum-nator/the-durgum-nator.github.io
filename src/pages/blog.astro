---
import BasePageLayout from "../layouts/BasePageLayout.astro";
import BlogPost from "../components/BlogPost.astro";
import "/src/styles/global.css";
const allPosts = Object.entries(
  import.meta.glob("../pages/posts/*.md", { eager: true })
);
const pageTitle = "Personal Blog";
---

<BasePageLayout pageTitle={pageTitle}>
  <h2>{pageTitle}</h2>
  <div class="content">
    <p>Here's a personal blog for myself, check it out!</p>
    <ul>
      {
        allPosts.map(([path, post]:any) => {
          return <BlogPost url={post.url} title={post.frontmatter.title} pubDate={post.frontmatter.pubDate}/>
          // add descriptions + styling for each box
        })
      }
    </ul>
</div>
</BasePageLayout>
