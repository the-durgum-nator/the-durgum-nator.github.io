---
import BasePageLayout from "../layouts/BasePageLayout.astro";
const pageTitle = "Home Page";
const username = "the-durgum-nator";
const platform = "github";
---

<BasePageLayout pageTitle={pageTitle} >
<div class="maincolumns">

  <div class="leftside">
    <div class="leftsidetop">

      <p> 
        You know, a really wise man once told me:<br>
        <em>"You never really lose at something until you give up at it."</em>
        <br>Might as well put some time towards that motto.
      </p>
      <p>
        Homepage of Rohan Durgum's website!
        <br> Made like it was written on paper.
        <br> That's how you know effort was put into it.
        <br> Minus the text, unless you use a typewriter.
      </p>
    </div>

    <div class="leftsidebottom">
       <p>
        Still trying to figure out how to fill out the page, so check back later for this.
      </p>
    </div>
  </div>
  
  <div class ="rightside">
    <div class="rightsidetop">
      <img src="/assets/personalsquare.jpg" alt="Selfie of Rohan Durgum">
    </div>

  <div class="rightsidebottom">
    <table>
    <tr>

      <th>
        Here's where you can contact me:
      </th>
    </tr>
    <tr>
      <td>
        Github:
        <a href={`https://www.${platform}.com/${username}`}> the-durgum-nator </a>
      </td>
    </tr>
    <tr>
      <td>
        LinkedIn:
        <a href={`https://www.linkedin.com/in/rohan-durgum-7b923b282`}>rohan-durgum</a>
      </td>
    </tr>
    <tr>
      <td>
        E-mail:
        <a href={`mailto:durgum.rohan@gmail.com`}>durgum.rohan@gmail.com</a>
      </td>
    </tr>
    </table> 
  </div>
</div>

</BasePageLayout>
